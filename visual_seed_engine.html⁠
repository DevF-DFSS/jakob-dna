    <script>
        // Native preview compile key link
        const apiKey = ""; 

        let activeMode = 'personal';
        
        // HARDCODING DEV'S EXACT GITHUB RAW CONTENT DIRECT ENDPOINT FOR TRUE OUT-OF-THE-BOX ALIGNMENT
        const defaultAnchor = "https://raw.githubusercontent.com/DevF-DFSS/jakob-dna/main/jakob_anchor.jpeg";

        // Multi-modal structuring instructions
        const templates = {
            baseJaKoB: "This is a rigid identity-anchor image. You MUST perfectly preserve the exact facial structure, bone geometry, hair style, eye shape, and identity of the person shown in the image. DO NOT change their face. Improvise the background, clothing, and environment based strictly on this prompt:",
            personalExtra: "He is holding the camera with an outstretched arm visible entering the frame from the lower-left corner (no physical phone is visible in his hand). Next to him is his friendly golden retriever, Buffer, looking up toward the camera with soft brown eyes and wearing a distinct blue service harness.",
            systemsExtra: "He is holding the camera with an outstretched arm visible entering the frame from the lower-left corner (no physical phone is visible in his hand).",
            styleFooter: "Illuminated by natural warm ambient light. Shot on a 35mm portrait lens, extremely shallow depth of field, sharp focus on his face, raw organic film texture, natural photographic shadows, absolutely no artificial plastic smoothing, no stock-model rendering."
        };

        // On Load initialization
        window.onload = function() {
            const savedUrl = localStorage.getItem('jakob_github_anchor_url');
            if (savedUrl) {
                document.getElementById('githubUrlInput').value = savedUrl;
                document.getElementById('referenceThumbnail').src = savedUrl;
            } else {
                document.getElementById('githubUrlInput').value = defaultAnchor;
                document.getElementById('referenceThumbnail').src = defaultAnchor;
            }
            updatePrompt();
        }

        function saveGithubUrl() {
            const val = document.getElementById('githubUrlInput').value.trim();
            if (val) {
                localStorage.setItem('jakob_github_anchor_url', val);
                document.getElementById('referenceThumbnail').src = val;
                triggerToast("GITHUB_LINK_LOCKED");
            } else {
                localStorage.removeItem('jakob_github_anchor_url');
                document.getElementById('referenceThumbnail').src = defaultAnchor;
                triggerToast("DEFAULT_ANCHOR_RESTORED");
            }
        }

        function setMode(mode) {
            activeMode = mode;
            const btnP = document.getElementById('btnPersonal');
            const btnS = document.getElementById('btnSystem');

            if (mode === 'personal') {
                btnP.className = "active-btn py-2.5 rounded-xl text-[9px] font-bold tracking-wider transition-all duration-300 flex items-center justify-center space-x-1";
                btnS.className = "inactive-btn py-2.5 rounded-xl text-[9px] font-bold tracking-wider transition-all duration-300 flex items-center justify-center space-x-1";
            } else {
                btnP.className = "inactive-btn py-2.5 rounded-xl text-[9px] font-bold tracking-wider transition-all duration-300 flex items-center justify-center space-x-1";
                btnS.className = "active-btn py-2.5 rounded-xl text-[9px] font-bold tracking-wider transition-all duration-300 flex items-center justify-center space-x-1";
            }
            updatePrompt();
        }

        function updatePrompt() {
            const loc = document.getElementById('locationInput').value.trim();
            const gear = document.getElementById('gearInput').value.trim();
            const extra = activeMode === 'personal' ? templates.personalExtra : templates.systemsExtra;

            const prompt = `${templates.baseJaKoB} Wearing ${gear}. ${extra} Setting: ${loc}. ${templates.styleFooter}`;
            document.getElementById('promptBox').value = prompt;
        }

        // Helper to fetch external image as blob and convert to Base64 for the payload
        async function fetchImageAsBase64(url) {
            const response = await fetch(url);
            const blob = await response.blob();
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onloadend = () => {
                    const base64 = reader.result.split(',')[1];
                    resolve(base64);
                };
                reader.onerror = reject;
                reader.readAsDataURL(blob);
            });
        }

        async function compileCloudIdentity() {
            const generateBtn = document.getElementById('generateBtn');
            const emptyState = document.getElementById('emptyState');
            const loader = document.getElementById('loader');
            const seedImage = document.getElementById('seedImage');
            const downloadBtn = document.getElementById('downloadBtn');
            const renderIndicator = document.getElementById('renderIndicator');

            emptyState.classList.add('hidden');
            seedImage.classList.add('hidden');
            downloadBtn.classList.add('hidden');
            loader.classList.remove('hidden');
            generateBtn.disabled = true;
            generateBtn.classList.add('opacity-50');
            renderIndicator.className = "w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse";

            const systemDirectives = document.getElementById('promptBox').value;
            const targetUrl = localStorage.getItem('jakob_github_anchor_url') || defaultAnchor;

            try {
                // Fetch static anchor
                const base64Anchor = await fetchImageAsBase64(targetUrl);

                const payload = {
                    contents: [{
                        parts: [
                            { text: systemDirectives },
                            {
                                inlineData: {
                                    mimeType: "image/jpeg",
                                    data: base64Anchor
                                }
                            }
                        ]
                    }],
                    generationConfig: {
                        responseModalities: ["IMAGE"]
                    }
                };

                const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-image-preview:generateContent?key=${apiKey}`;

                let result = null;
                let delay = 1000;

                for (let i = 0; i < 5; i++) {
                    try {
                        const response = await fetch(url, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                        if (response.ok) {
                            result = await response.json();
                            break;
                        }
                    } catch (e) {}
                    await new Promise(resolve => setTimeout(resolve, delay));
                    delay *= 2;
                }

                if (!result || !result.candidates || !result.candidates[0]) {
                    throw new Error("Cloud Sync compile failed. Ensure your GitHub raw URL is publicly accessible.");
                }

                const outBase64 = result.candidates[0].content.parts.find(p => p.inlineData)?.inlineData?.data;
                
                if (!outBase64) {
                    throw new Error("No image prediction returned from cloud alignment.");
                }

                seedImage.src = `data:image/jpeg;base64,${outBase64}`;
                seedImage.classList.remove('hidden');
                downloadBtn.classList.remove('hidden');
                renderIndicator.className = "w-1.5 h-1.5 rounded-full bg-emerald-500";
                triggerToast("COMPILE_SUCCESS");

            } catch (err) {
                showError(err.message);
                emptyState.classList.remove('hidden');
                renderIndicator.className = "w-1.5 h-1.5 rounded-full bg-rose-500";
            } finally {
                loader.classList.add('hidden');
                generateBtn.disabled = false;
                generateBtn.classList.remove('opacity-50');
            }
        }

        function downloadImage() {
            const img = document.getElementById('seedImage');
            if (!img.src) return;
            const a = document.createElement('a');
            a.href = img.src;
            a.download = `JaKoB_Seed_${Date.now()}.png`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }

        function showError(msg) {
            document.getElementById('errorText').innerText = msg;
            document.getElementById('errorModal').classList.remove('hidden');
        }

        function closeError() {
            document.getElementById('errorModal').classList.add('hidden');
        }

        function triggerToast(text) {
            const toast = document.getElementById('toast');
            const toastText = document.getElementById('toastText');
            toastText.innerText = text;
            toast.className = "opacity-100 translate-y-0 fixed bottom-6 right-6 glass-base px-5 py-3 rounded-xl transition-all duration-300 z-50 flex items-center space-x-2 text-[#00ff66] border border-emerald-500/20";
            
            setTimeout(() => {
                toast.className = "opacity-0 translate-y-4 pointer-events-none fixed bottom-6 right-6 glass-base px-5 py-3 rounded-xl transition-all duration-300 z-50 flex items-center space-x-2 text-[#00ff66] border border-emerald-500/20";
            }, 3000);
        }
    </script>
</body>
</html>

